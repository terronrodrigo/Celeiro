{
  "name": "celeiro-dashboard-api",
  "version": "1.0.2",
  "description": "API da plataforma de voluntários Celeiro São Paulo (check-in, escalas, Resend)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node scripts/sync-mongo.js",
    "update-db": "node scripts/update-db.js",
    "fix-planilha-celeiro": "node scripts/fix-planilha-voluntarios-celeiro.js",
    "create-voluntario-test": "node scripts/create-voluntario-test.js",
    "criar-igreja-inc-adolescentes": "SOURCE_IGREJA_SLUG=inc-sp NOVA_IGREJA_NOME='INC Adolescentes' NOVA_IGREJA_SLUG=inc-adolescentes node scripts/criar-igreja-clone-ministerios.js",
    "seed-ministerios-celeiro": "node scripts/seed-ministerios-celeiro.js",
    "import-users-mongo-to-pg": "node scripts/import-users-mongo-to-pg.js",
    "import-lideres-csv": "node scripts/import-lideres-csv.js",
    "purge-checkin-orfaos": "node scripts/purge-eventos-checkin-orfaos.js",
    "test": "node --test test/*.test.js test/*.test.mjs",
    "test:unit": "node --test test/*.test.js test/*.test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "resend": "^4.0.0",
    "sharp": "^0.33.5"
  }
}
